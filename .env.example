# Database (Neon: pooled URL is fine for the app)
DATABASE_URL=postgresql://...

# Optional: direct (non-pooler) URL for `npx prisma migrate` if you see P1002 advisory lock timeouts.
# Copy from Neon → Connection string → "Direct connection". Do not use for serverless runtime if you rely on pooling.
# MIGRATE_DATABASE_URL=postgresql://...

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google Maps Platform
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_CLIENT_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_CLIENT_KEY=

# TripAdvisor
TRIPADVISOR_API_KEY=

# Gemini AI
GEMINI_API_KEY=

# Access control (comma-separated Google emails, leave empty to allow all)
# ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com

# Dev only: skip Google OAuth (never set in production)
# BYPASS_AUTH=true
